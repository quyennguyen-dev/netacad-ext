{
  "manifest_version": 3,
  "name": "NetAcad Scraper",
  "version": "1.2",
  "description": "Scrapes questions from NetAcad pages and saves them to a local file.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.netacad.com/*"
      ],
      "js": [
        "utils.js",
        "api.js",
        "ui.js",
        "scraper.js",
        "autoloop.js",
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "images/icon-48x48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "process-page-command": {
      "suggested_key": {
        "default": "Alt+Shift+Q",
        "mac": "Alt+Shift+Q"
      },
      "description": "Process Questions on this Page"
    }
  },
  "icons": {
    "48": "images/icon-48x48.png"
  }
}